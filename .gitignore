# Python bytecode and caches
__pycache__/
*.py[cod]
*$py.class

# C extensions
*.pyd
*.so

# Packaging and build artifacts
.Python
build/
dist/
*.egg-info/
.eggs/
*.egg
pip-wheel-metadata/

# Virtual environments (even if not used by default)
.venv/
venv/
env/
ENV/

# Test, coverage, and type-check caches
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.mypy_cache/
.ruff_cache/
.pyre/
.hypothesis/

# IDE/editor settings
.vscode/
.idea/
*.swp
*.swo

# OS files
.DS_Store
Thumbs.db

# Project runtime outputs
log/*.log
cache/

# Encrypted password and key — NEVER commit these
data/.secret.key
data/.password.enc

# Local environment/config overrides
.env
.env.*
*.local
